---
interface Props {
	pdfUrl?: string;
}

const { pdfUrl = "/Lawson_Hart_Resume.pdf" } = Astro.props;
---

<span class="inline-flex items-center gap-1 align-baseline" data-resume-root data-pdf-url={pdfUrl}>
	<button
		type="button"
		data-resume-trigger
		class="lawson-link inline-flex items-center gap-1 text-[15px] font-normal underline decoration-dotted underline-offset-4 hover:decoration-solid transition-all"
	>
		<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
			<path
				stroke-linecap="round"
				stroke-linejoin="round"
				stroke-width="2"
				d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
			></path>
		</svg>
		View/download my resume
	</button>

	<div
		data-resume-modal
		hidden
		class="fixed inset-0 z-[9999] flex items-center justify-center bg-global-bg/70 px-4"
		role="presentation"
	>
		<dialog
			open
			aria-labelledby="resume-modal-title"
			aria-modal="true"
			class="relative w-full max-w-4xl rounded-2xl border border-global-text/15 bg-global-bg p-4"
		>
			<div class="flex items-center justify-between gap-4 border-b border-global-text/10 pb-3">
				<div>
					<p id="resume-modal-title" class="text-lg font-semibold text-accent-2">
						Resume preview
					</p>
					<p class="text-sm text-global-text/70">
						Download or open the PDF directly from here.
					</p>
				</div>
				<div class="flex items-center gap-2">
					<a
						data-resume-download
						href={pdfUrl}
						download
						class="inline-flex items-center gap-2 rounded-lg border border-accent/45 px-3 py-1.5 text-sm font-medium text-accent transition-colors hover:border-accent hover:bg-accent/10"
					>
						<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M4 16v1a2 2 0 002 2h12a2 2 0 002-2v-1M7 10l5 5m0 0l5-5m-5 5V4"
							></path>
						</svg>
						Download PDF
					</a>
					<button
						type="button"
						data-resume-close
						class="inline-flex items-center rounded-lg border border-global-text/15 px-3 py-1.5 text-sm text-global-text transition-colors hover:border-accent/40 hover:text-accent hover:bg-accent/5"
					>
						Close
					</button>
				</div>
			</div>

			<div data-resume-preview>
				<div
					class="mt-4 overflow-hidden rounded-xl border border-global-text/15 bg-global-text/[0.03]"
				>
					<iframe title="Resume preview" data-resume-iframe src="" class="h-[70vh] w-full"
					></iframe>
				</div>
				<p class="mt-3 text-xs text-global-text/60">
					Having trouble viewing the PDF?{" "}
					<a class="underline" href={pdfUrl} target="_blank" rel="noreferrer">
						Open it in a new tab.
					</a>
				</p>
			</div>

			<p data-resume-notfound hidden class="mt-4 text-sm text-global-text/80">
				Resume PDF not found at <span class="font-mono">{pdfUrl}</span>. Add a PDF at that path
				(or pass a different <span class="font-mono">pdfUrl</span> prop) to enable preview/download.
			</p>
		</dialog>
	</div>
</span>

<script>
	for (const root of document.querySelectorAll<HTMLElement>("[data-resume-root]")) {
		const pdfUrl = root.dataset.pdfUrl ?? "/Lawson_Hart_Resume.pdf";
		const trigger = root.querySelector<HTMLButtonElement>("[data-resume-trigger]");
		const modal = root.querySelector<HTMLElement>("[data-resume-modal]");
		const closeBtn = root.querySelector<HTMLButtonElement>("[data-resume-close]");
		const downloadLink = root.querySelector<HTMLElement>("[data-resume-download]");
		const preview = root.querySelector<HTMLElement>("[data-resume-preview]");
		const notFound = root.querySelector<HTMLElement>("[data-resume-notfound]");
		const iframe = root.querySelector<HTMLIFrameElement>("[data-resume-iframe]");
		if (!trigger || !modal || !closeBtn) continue;

		const onKeyDown = (event: KeyboardEvent) => {
			if (event.key === "Escape") close();
		};

		const open = () => {
			modal.hidden = false;
			document.body.style.overflow = "hidden";
			document.addEventListener("keydown", onKeyDown);
			closeBtn.focus();

			// Reset to "checking" state, then probe availability with a HEAD request.
			downloadLink?.removeAttribute("hidden");
			preview?.removeAttribute("hidden");
			notFound?.setAttribute("hidden", "");
			if (iframe) iframe.src = pdfUrl;

			fetch(pdfUrl, { method: "HEAD" })
				.then((res) => applyAvailability(res.ok))
				.catch(() => applyAvailability(false));
		};

		const applyAvailability = (available: boolean) => {
			if (modal.hidden) return; // user already closed it
			if (available) {
				downloadLink?.removeAttribute("hidden");
				preview?.removeAttribute("hidden");
				notFound?.setAttribute("hidden", "");
			} else {
				downloadLink?.setAttribute("hidden", "");
				preview?.setAttribute("hidden", "");
				notFound?.removeAttribute("hidden");
				if (iframe) iframe.src = "";
			}
		};

		const close = () => {
			modal.hidden = true;
			document.body.style.overflow = "";
			document.removeEventListener("keydown", onKeyDown);
			if (iframe) iframe.src = "";
		};

		trigger.addEventListener("click", open);
		closeBtn.addEventListener("click", close);
		modal.addEventListener("click", (event) => {
			if (event.target === modal) close();
		});
	}
</script>
