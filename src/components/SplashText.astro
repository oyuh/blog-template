---
import { FEATURED_SPLASH_TEXT, SPLASH_HOLD_MS, SPLASH_TEXTS } from "@/data/splashTexts";

type Props = {
	intervalMs?: number;
	holdMs?: number;
	class?: string;
};

const {
	intervalMs = 4500,
	holdMs = SPLASH_HOLD_MS,
	class: className = "",
} = Astro.props as Props;

// The featured phrase is the default face of the page (SSR + no-JS paint).
const fallbackText = FEATURED_SPLASH_TEXT;
const texts = SPLASH_TEXTS;
---

<span
	class={className}
	data-splash-text
	data-splash-interval-ms={String(intervalMs)}
	data-splash-hold-ms={String(holdMs)}
	data-splash-texts={JSON.stringify(texts)}
>
	{fallbackText}
</span>

<script>
	import "@/scripts/splashText";
</script>
