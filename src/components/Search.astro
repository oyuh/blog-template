---
// Inline header search powered by the Pagefind JS API (no modal). The header bar
// IS the input; results drop into a panel directly below it, with a toggleable
// Tags + Technology filter menu. Dismiss by clearing the query or clicking outside
// a result. Pagefind only exists in a production build, so dev shows a note.
import "@/styles/blocks/search.css";
---

<site-search id="search" class="site-search">
	<div class="site-search__bar" data-bar>
		<span class="site-search__lead">
			<svg
				class="site-search__icon"
				aria-hidden="true"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="1.7"
				stroke-linecap="round"
				stroke-linejoin="round"
				data-glass
			>
				<circle cx="11" cy="11" r="7"></circle>
				<path d="M21 21l-4.3-4.3"></path>
			</svg>
			<span class="site-search__count" data-count hidden aria-hidden="true"></span>
		</span>
		<input
			type="search"
			class="site-search__input"
			placeholder="Search…"
			aria-label="Search the site"
			autocomplete="off"
			spellcheck="false"
			data-input
		/>
		<button type="button" class="site-search__clear" data-clear hidden aria-label="Clear search">
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<path d="M6 6l12 12M18 6L6 18"></path>
			</svg>
		</button>
	</div>

	<div class="site-search__panel" data-panel hidden role="region" aria-label="Search results">
		<div class="site-search__toolbar">
			<button type="button" class="site-search__filter-toggle" data-filter-toggle aria-expanded="false">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="M4 5h16M7 12h10M10 19h4"></path>
				</svg>
				<span>Filters</span>
				<span class="site-search__filter-badge" data-filter-count hidden></span>
			</button>
			<button type="button" class="site-search__filter-clear" data-clear-filters hidden>Clear filters</button>
		</div>

		<div class="site-search__filters" data-filters hidden>
			<div class="site-search__filter-group">
				<h4 class="site-search__filter-title">Tags</h4>
				<div class="site-search__chips" data-chips="tag"></div>
			</div>
			<div class="site-search__filter-group">
				<h4 class="site-search__filter-title">Technology</h4>
				<div class="site-search__chips" data-chips="tech"></div>
			</div>
		</div>

		<div class="site-search__results" data-results></div>
	</div>
</site-search>

<script>
	const MAX_RESULTS = 8;
	const DEV = import.meta.env.DEV;
	const PAGEFIND_PATH = import.meta.env.BASE_URL.replace(/\/$/, "") + "/pagefind/pagefind.js";

	type SubResult = { title: string; url: string; excerpt: string };
	type ResultData = {
		url: string;
		meta?: { title?: string };
		excerpt: string;
		sub_results?: SubResult[];
	};
	type FilterCounts = Record<string, Record<string, number>>;

	const escapeHtml = (s: string) =>
		s.replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" })[c] as string);

	class SiteSearch extends HTMLElement {
		#input = this.querySelector<HTMLInputElement>("[data-input]");
		#clear = this.querySelector<HTMLButtonElement>("[data-clear]");
		#panel = this.querySelector<HTMLElement>("[data-panel]");
		#results = this.querySelector<HTMLElement>("[data-results]");
		#glass = this.querySelector<SVGElement>("[data-glass]");
		#count = this.querySelector<HTMLElement>("[data-count]");
		#filterToggle = this.querySelector<HTMLButtonElement>("[data-filter-toggle]");
		#filterBadge = this.querySelector<HTMLElement>("[data-filter-count]");
		#filters = this.querySelector<HTMLElement>("[data-filters]");
		#clearFilters = this.querySelector<HTMLButtonElement>("[data-clear-filters]");
		#pagefind: any = null;
		#loadingPagefind = false;
		#filtersLoaded = false;
		#selected: { tag: Set<string>; tech: Set<string> } = { tag: new Set(), tech: new Set() };
		#debounce = 0;
		#token = 0;
		#controller = new AbortController();

		connectedCallback() {
			const signal = this.#controller.signal;
			this.#input?.addEventListener("input", this.onInput, { signal });
			this.#input?.addEventListener("focus", this.onFocus, { signal });
			this.#clear?.addEventListener("click", this.onClear, { signal });
			this.#filterToggle?.addEventListener("click", this.onToggleFilters, { signal });
			this.#clearFilters?.addEventListener("click", this.onClearFilters, { signal });
			this.#filters?.addEventListener("click", this.onChipClick, { signal });
			document.addEventListener("click", this.onDocClick, { signal });
			document.addEventListener("keydown", this.onKeydown, { signal });
		}

		disconnectedCallback() {
			this.#controller.abort();
			clearTimeout(this.#debounce);
		}

		async loadPagefind() {
			if (this.#pagefind || this.#loadingPagefind) return this.#pagefind;
			this.#loadingPagefind = true;
			try {
				this.#pagefind = await import(/* @vite-ignore */ PAGEFIND_PATH);
				await this.#pagefind.options?.({ excerptLength: 18 });
			} catch {
				this.#pagefind = null;
			} finally {
				this.#loadingPagefind = false;
			}
			return this.#pagefind;
		}

		async loadFilters() {
			if (this.#filtersLoaded || DEV) return;
			const pf = await this.loadPagefind();
			if (!pf?.filters) return;
			const counts: FilterCounts = await pf.filters();
			this.#filtersLoaded = true;
			this.renderChips("tag", counts.tag ?? {});
			this.renderChips("tech", counts.tech ?? {});
		}

		renderChips(key: string, values: Record<string, number>) {
			const wrap = this.querySelector<HTMLElement>(`[data-chips="${key}"]`);
			if (!wrap) return;
			const entries = Object.entries(values).sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
			if (entries.length === 0) {
				wrap.innerHTML = `<span class="site-search__chips-empty">None</span>`;
				return;
			}
			wrap.innerHTML = entries
				.map(
					([val, count]) =>
						`<button type="button" class="site-search__chip" data-filter="${key}" data-value="${escapeHtml(val)}">${escapeHtml(val)}<span class="site-search__chip-count">${count}</span></button>`,
				)
				.join("");
		}

		buildFilters() {
			const out: Record<string, string[]> = {};
			if (this.#selected.tag.size > 0) out.tag = [...this.#selected.tag];
			if (this.#selected.tech.size > 0) out.tech = [...this.#selected.tech];
			return out;
		}

		selectedCount() {
			return this.#selected.tag.size + this.#selected.tech.size;
		}

		onFocus = () => {
			if (!DEV) {
				this.loadPagefind();
				this.loadFilters();
			}
			this.openPanel();
			this.refresh();
		};

		onInput = () => {
			const value = this.#input?.value ?? "";
			if (this.#clear) this.#clear.hidden = value.length === 0;
			clearTimeout(this.#debounce);
			this.#debounce = window.setTimeout(() => this.refresh(), 180);
		};

		// Re-run search from the current query + selected filters.
		refresh = async () => {
			const query = (this.#input?.value ?? "").trim();
			const filters = this.buildFilters();
			const hasFilters = Object.keys(filters).length > 0;
			this.openPanel();
			if (!DEV) this.loadFilters();

			if (DEV) {
				this.renderMessage("Search runs on the built site — try it after a production build.");
				return;
			}
			if (!query && !hasFilters) {
				this.updateCount(0);
				this.renderMessage("Type to search, or pick a filter.");
				return;
			}

			const token = ++this.#token;
			const pf = await this.loadPagefind();
			if (token !== this.#token) return;
			if (!pf) {
				this.renderMessage("Search isn’t available right now.");
				return;
			}

			const search = await pf.search(query || null, hasFilters ? { filters } : undefined);
			if (token !== this.#token) return;
			const total: number = search.results.length;
			const data: ResultData[] = await Promise.all(
				search.results.slice(0, MAX_RESULTS).map((r: any) => r.data()),
			);
			if (token !== this.#token) return;
			this.updateCount(total);
			this.renderResults(data);
		};

		updateCount(total: number) {
			if (!this.#glass || !this.#count) return;
			if (total > 0) {
				this.#count.textContent = total > 99 ? "99+" : String(total);
				this.#count.hidden = false;
				this.#glass.style.display = "none";
			} else {
				this.#count.hidden = true;
				this.#glass.style.display = "";
			}
		}

		renderMessage(message: string) {
			if (this.#results) this.#results.innerHTML = `<p class="site-search__message">${message}</p>`;
		}

		renderResults(data: ResultData[]) {
			if (!this.#results) return;
			if (data.length === 0) {
				this.#results.innerHTML = `<p class="site-search__message">No results.</p>`;
				return;
			}
			this.#results.innerHTML = data
				.map((d) => {
					const title = escapeHtml(d.meta?.title || d.url);
					const subs = (d.sub_results ?? [])
						.slice(0, 2)
						.map(
							(s) =>
								`<a class="site-search__sub" href="${escapeHtml(s.url)}"><span class="site-search__sub-title">${escapeHtml(s.title)}</span><span class="site-search__sub-excerpt">${s.excerpt}</span></a>`,
						)
						.join("");
					return `<div class="site-search__result"><a class="site-search__result-link" href="${escapeHtml(d.url)}">${title}</a><p class="site-search__result-excerpt">${d.excerpt}</p>${subs}</div>`;
				})
				.join("");
		}

		onChipClick = (e: MouseEvent) => {
			const chip = (e.target as HTMLElement)?.closest<HTMLElement>(".site-search__chip");
			if (!chip) return;
			const key = chip.dataset.filter;
			const value = chip.dataset.value ?? "";
			if (key !== "tag" && key !== "tech") return;
			const set = this.#selected[key];
			if (set.has(value)) {
				set.delete(value);
				chip.classList.remove("is-active");
			} else {
				set.add(value);
				chip.classList.add("is-active");
			}
			this.syncFilterChrome();
			this.refresh();
		};

		syncFilterChrome() {
			const count = this.selectedCount();
			if (this.#filterBadge) {
				this.#filterBadge.textContent = String(count);
				this.#filterBadge.hidden = count === 0;
			}
			if (this.#clearFilters) this.#clearFilters.hidden = count === 0;
			this.#filterToggle?.classList.toggle("is-active", count > 0);
		}

		onToggleFilters = () => {
			if (!this.#filters || !this.#filterToggle) return;
			if (!DEV) this.loadFilters();
			const open = this.#filters.hidden;
			this.#filters.hidden = !open;
			this.#filterToggle.setAttribute("aria-expanded", String(open));
		};

		onClearFilters = () => {
			this.#selected.tag.clear();
			this.#selected.tech.clear();
			this.querySelectorAll(".site-search__chip.is-active").forEach((c) => c.classList.remove("is-active"));
			this.syncFilterChrome();
			this.refresh();
		};

		openPanel() {
			if (this.#panel) this.#panel.hidden = false;
			this.setAttribute("data-open", "true");
		}

		closePanel() {
			if (this.#panel) this.#panel.hidden = true;
			this.removeAttribute("data-open");
		}

		onClear = () => {
			if (this.#input) this.#input.value = "";
			if (this.#clear) this.#clear.hidden = true;
			this.#token++;
			this.updateCount(0);
			this.renderResults([]);
			this.closePanel();
			this.#input?.focus();
		};

		// Click anywhere that isn't the search component → close the panel.
		onDocClick = (e: MouseEvent) => {
			if (this.contains(e.target as Node)) return;
			this.closePanel();
		};

		onKeydown = (e: KeyboardEvent) => {
			if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === "k") {
				e.preventDefault();
				this.#input?.focus();
				this.#input?.select();
				return;
			}
			if (e.key === "Escape" && this.hasAttribute("data-open")) {
				this.closePanel();
				this.#input?.blur();
			}
		};
	}

	if (!customElements.get("site-search")) customElements.define("site-search", SiteSearch);
</script>
