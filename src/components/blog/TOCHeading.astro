---
import type { TocItem } from "@/utils/generateToc";

interface Props {
	heading: TocItem;
}

const {
	heading: { children, depth, slug, text },
} = Astro.props;
---

<li class="toc-item">
	<a class="toc-link" href={`#${slug}`} data-toc-link data-depth={depth}>
		{text}
	</a>

	{!!children.length && (
		<ol class="toc-children">
			{children.map((subheading) => (
				<Astro.self heading={subheading} />
			))}
		</ol>
	)}
</li>

<style is:global>
	/* Shared TOC link styling for both the desktop sidebar and mobile sheet. */
	a[data-toc-link] {
		display: block;
		border-radius: 0.5rem;
		padding: 0.3rem 0.55rem;
		line-height: 1.35;
		text-decoration: none;
		word-break: break-word;
		transition:
			color 0.18s ease,
			background-color 0.18s ease;
	}

	/*
	 * Depth hierarchy — a distinct size + colour for every heading level (h1–h6).
	 * The site font (Atkinson Hyperlegible) only ships 400 + 700, so weight steps
	 * between bold (h1–h2) and regular (h3–h6); size and colour carry the rest.
	 */
	a[data-toc-link][data-depth="1"] {
		font-size: 1rem;
		font-weight: 700;
		letter-spacing: 0.01em;
		color: var(--color-accent-2);
	}

	a[data-toc-link][data-depth="2"] {
		font-size: 0.9rem;
		font-weight: 700;
		color: var(--color-accent-2);
	}

	a[data-toc-link][data-depth="3"] {
		font-size: 0.82rem;
		font-weight: 400;
		color: color-mix(in srgb, var(--color-global-text) 92%, transparent);
	}

	a[data-toc-link][data-depth="4"] {
		font-size: 0.76rem;
		font-weight: 400;
		color: color-mix(in srgb, var(--color-global-text) 74%, transparent);
	}

	a[data-toc-link][data-depth="5"] {
		font-size: 0.72rem;
		font-weight: 400;
		color: color-mix(in srgb, var(--color-global-text) 60%, transparent);
	}

	a[data-toc-link][data-depth="6"] {
		font-size: 0.68rem;
		font-weight: 400;
		font-style: italic;
		color: color-mix(in srgb, var(--color-global-text) 50%, transparent);
	}

	/* Hover: underline only — no background pill (flat redesign). */
	@media (hover: hover) {
		a[data-toc-link]:hover {
			text-decoration: underline;
			text-decoration-color: color-mix(in srgb, var(--color-accent) 45%, transparent);
			text-underline-offset: 3px;
		}
	}

	/* Current section: blue text only — no background highlight. */
	a[data-toc-link][data-active="true"] {
		color: var(--color-accent);
		font-weight: 700;
	}

	/*
	 * Nested levels are indented behind a vertical guide line so the depth of
	 * each heading is obvious at a glance.
	 */
	ol.toc-children {
		margin-top: 0.125rem;
		margin-left: 0.5rem;
		padding-left: 0.6rem;
		border-left: 1px solid color-mix(in srgb, var(--color-global-text) 16%, transparent);
	}

	ol.toc-children > li + li {
		margin-top: 0.125rem;
	}

	/* Brighten the guide line that leads to the currently-active heading. */
	ol.toc-children:has(> li > a[data-active="true"]),
	ol.toc-children:has(a[data-active="true"]) {
		border-left-color: color-mix(in srgb, var(--color-accent) 45%, transparent);
	}
</style>
