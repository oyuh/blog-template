---
import { generateToc } from "@/utils/generateToc";
import type { MarkdownHeading } from "astro";
import TOCHeading from "./TOCHeading.astro";

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;
const toc = generateToc(headings);
---

{toc.length > 0 && (
  <aside
    class="hidden lg:flex lg:flex-col lg:gap-8 lg:order-2 lg:self-start"
    id="post-aside"
  >
    <!-- Table of contents: flat, separated by a line on its left, hideable. -->
    <nav id="toc-dock" class="toc-dock" data-collapsed="false" aria-label="Table of contents">
      <button
        type="button"
        id="toc-toggle"
        class="toc-dock__head"
        aria-expanded="true"
        aria-controls="toc-nav"
        title="Hide"
      >
        <span class="toc-dock__title">Content</span>
        <span class="toc-dock__toggle" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M6 9l6 6 6-6" />
          </svg>
        </span>
      </button>
      <div id="toc-nav" class="toc-dock__nav">
        <ol id="toc-list">
          {toc.map((heading) => <TOCHeading heading={heading} />)}
        </ol>
      </div>
    </nav>

    <!-- Comments dock: flat, hidden by default. Lives under the TOC, and floats
         into the left gutter on very wide screens (see media query below). -->
    <div id="comments-dock" class="comments-dock">
      <slot />
    </div>
  </aside>
)}

<script>
  // ---- Hide / show the table of contents (persisted per page) ----
  const dock = document.getElementById('toc-dock') as HTMLElement | null;
  const toggleBtn = document.getElementById('toc-toggle') as HTMLButtonElement | null;
  const list = document.getElementById('toc-list') as HTMLOListElement | null;

  const collapseKey = `toc-collapsed:${location.pathname}`;

  const setCollapsed = (collapsed: boolean) => {
    if (!dock) return;
    dock.dataset.collapsed = String(collapsed);
    toggleBtn?.setAttribute('aria-expanded', String(!collapsed));
    toggleBtn?.setAttribute('title', collapsed ? 'Show' : 'Hide');
    try { localStorage.setItem(collapseKey, String(collapsed)); } catch {}
  };

  toggleBtn?.addEventListener('click', () => {
    setCollapsed(dock?.dataset.collapsed !== 'true');
  });

  const initCollapsed = () => {
    try {
      if (localStorage.getItem(collapseKey) === 'true') setCollapsed(true);
    } catch {}
  };

  // ---- Scrollspy highlighting ----
  // Scope to the article prose so hidden, position:fixed headings from the
  // mobile nav / mobile TOC ("Where to next?", "Contents") never get picked.
  const headingSelector = '.blog-prose h1, .blog-prose h2, .blog-prose h3, .blog-prose h4, .blog-prose h5, .blog-prose h6';
  const headings = Array.from(document.querySelectorAll(headingSelector)) as HTMLElement[];
  const anchorMap = new Map<string, HTMLAnchorElement>();
  list?.querySelectorAll('a[data-toc-link]').forEach((a) => {
    const id = (a.getAttribute('href') || '').slice(1);
    if (id) anchorMap.set(id, a as HTMLAnchorElement);
  });

  let activeId: string | null = null;
  const setActive = (id: string | null) => {
    if (activeId === id) return;

    // Clear active state on the previous link (depth styling lives in CSS).
    if (activeId && anchorMap.has(activeId)) {
      anchorMap.get(activeId)!.removeAttribute('data-active');
    }

    activeId = id;

    // Mark the new link active and keep it in view within the TOC.
    if (activeId && anchorMap.has(activeId)) {
      const el = anchorMap.get(activeId)!;
      el.setAttribute('data-active', 'true');
      el.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
    }
  };

  // Compute which heading the reader is currently on. Driven by scroll +
  // IntersectionObserver + resize so the highlight is *always* present, even
  // when a slow scroll never crosses an observer threshold.
  let headingEls = headings;
  const computeActive = () => {
    if (headingEls.length === 0) return;
    const headerOffset = parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--header-clearance')) || 72;
    const scrollTop = window.scrollY + headerOffset + 20; // small buffer for accuracy

    const headingPositions = headingEls.map(h => ({
      element: h,
      id: h.getAttribute('id'),
      top: h.getBoundingClientRect().top + window.scrollY,
      level: parseInt(h.tagName.charAt(1)),
    })).filter(h => h.id && anchorMap.has(h.id)); // only headings that exist in the TOC

    if (headingPositions.length === 0) return;

    headingPositions.sort((a, b) => a.top - b.top);

    // Closest heading at or above the current scroll position…
    let activeHeading = null;
    for (let i = headingPositions.length - 1; i >= 0; i--) {
      const heading = headingPositions[i];
      if (heading && heading.top <= scrollTop + 10) {
        activeHeading = heading;
        break;
      }
    }
    // …otherwise (near the very top) fall back to the first heading so there
    // is always something highlighted.
    if (!activeHeading) activeHeading = headingPositions[0];

    // Prefer the next same/higher-level heading when we're closer to it.
    if (activeHeading) {
      const currentLevel = activeHeading.level;
      const currentIndex = headingPositions.findIndex(h => h.id === activeHeading!.id);
      for (let i = currentIndex + 1; i < headingPositions.length; i++) {
        const nextHeading = headingPositions[i];
        if (nextHeading) {
          if (nextHeading.level <= currentLevel) {
            const distanceToNext = Math.abs(nextHeading.top - scrollTop);
            const distanceToCurrent = Math.abs(activeHeading!.top - scrollTop);
            if (distanceToNext < distanceToCurrent && distanceToNext < 200) {
              activeHeading = nextHeading;
            }
            break;
          }
        }
      }
    }

    if (activeHeading?.id) setActive(activeHeading.id);
  };

  // rAF-throttled scroll/resize tracking — the reliable source of truth.
  let ticking = false;
  const onScroll = () => {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => { computeActive(); ticking = false; });
  };

  // IntersectionObserver is a secondary trigger (catches programmatic jumps).
  const io = new IntersectionObserver(() => computeActive(), {
    rootMargin: `-${getComputedStyle(document.documentElement).getPropertyValue('--header-clearance') || '72px'} 0px -70% 0px`,
    threshold: [0, 0.25, 0.5, 0.75, 1],
  });

  const init = () => {
    initCollapsed();
    headingEls.forEach((h) => io.observe(h));
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    computeActive(); // highlight immediately, before any scroll
  };

  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    setTimeout(init, 0);
  } else {
    document.addEventListener('DOMContentLoaded', init);
  }

  // Update on client-side navigation (Astro view transitions).
  document.addEventListener('astro:page-load', () => {
    io.disconnect();
    anchorMap.clear();
    list?.querySelectorAll('a[data-toc-link]').forEach((a) => {
      const id = (a.getAttribute('href') || '').slice(1);
      if (id) anchorMap.set(id, a as HTMLAnchorElement);
    });
    headingEls = Array.from(document.querySelectorAll(headingSelector)) as HTMLElement[];
    activeId = null;
    headingEls.forEach((h) => io.observe(h));
    computeActive();
  });
</script>

<style is:global>
  /*
   * Flat table of contents — separated from the article by a line on its left,
   * no card / shadow / blur. Hideable via the header chevron.
   */
  .toc-dock {
    border-left: 2px solid color-mix(in srgb, var(--color-global-text) 14%, transparent);
    padding-left: 1rem;
  }

  .toc-dock__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.6rem;
    width: 100%;
    padding: 0;
    background: none;
    border: 0;
    font: inherit;
    text-align: left;
    cursor: pointer;
  }

  .toc-dock__title {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-global-text) 55%, transparent);
  }

  .toc-dock__toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 1.5rem;
    width: 1.5rem;
    border-radius: 0.375rem;
    color: color-mix(in srgb, var(--color-global-text) 55%, transparent);
    cursor: pointer;
    transition: color 0.18s ease;
  }

  .toc-dock__toggle svg {
    height: 0.95rem;
    width: 0.95rem;
    transition: transform 0.2s ease;
  }

  @media (hover: hover) {
    .toc-dock__head:hover .toc-dock__toggle {
      color: var(--color-accent);
    }
    .toc-dock__head:hover .toc-dock__title {
      text-decoration: underline;
    }
  }

  /* Chevron points up while expanded (click = hide), down while collapsed (click = show). */
  #toc-dock:not([data-collapsed="true"]) .toc-dock__toggle svg {
    transform: rotate(180deg);
  }

  #toc-dock[data-collapsed="true"] .toc-dock__nav {
    display: none;
  }

  .toc-dock__nav {
    max-height: 60vh;
    overflow: auto;
    animation: toc-fade-in 0.2s ease-out;
  }

  .toc-dock__nav ol {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  #toc-list > li + li {
    margin-top: 0.1rem;
  }

  /*
   * Comments dock — flat, separated by a line on its left. Hidden behind a
   * toggle by default (the comments island renders its own collapsible header).
   * When the island has no content (comments disabled / not signed-in render),
   * collapse the dock so we never show an empty bordered box.
   */
  .comments-dock {
    border-left: 2px solid color-mix(in srgb, var(--color-global-text) 14%, transparent);
    padding-left: 1rem;
  }

  #comments-dock:not(:has(.comments-dock__inner)) {
    display: none;
  }

  /*
   * Desktop sidebar (lg → 1700px): pinned column to the right of the article.
   * TOC sits on top, comments dock under it.
   */
  @media (min-width: 1024px) {
    #post-aside {
      position: sticky;
      top: var(--header-clearance, 72px);
      flex: 0 0 20rem;
      width: 20rem;
      max-width: 20rem;
      align-self: flex-start;
      max-height: calc(100vh - var(--header-clearance, 72px) - 1.5rem);
    }
  }

  /*
   * Wide screens (≥ 1700px): the article keeps the centred body width, the TOC
   * floats into the right gutter, and the comments dock floats into the LEFT
   * gutter (its separating line flips to the right so it faces the article).
   */
  @media (min-width: 1700px) {
    #post-aside {
      position: fixed;
      top: var(--header-clearance, 72px);
      left: calc(50% + 32rem + 1.5rem);
      flex: none;
      width: clamp(13rem, 16.5rem, calc(50vw - 34.5rem));
      max-width: none;
      max-height: none;
    }

    #comments-dock {
      position: fixed;
      top: var(--header-clearance, 72px);
      left: auto;
      right: calc(50% + 32rem + 1.5rem);
      width: clamp(13rem, 16.5rem, calc(50vw - 34.5rem));
      max-height: calc(100vh - var(--header-clearance, 72px) - 1.5rem);
      overflow: auto;
      border-left: 0;
      border-right: 2px solid color-mix(in srgb, var(--color-global-text) 14%, transparent);
      padding-left: 0;
      padding-right: 1rem;
    }
  }
</style>
