---
// Contact links as legible, labelled cards (platform + handle). Flat + themed to
// match the rest of the site; accent on hover.
import { Icon } from "astro-icon/components";

type Social = {
	friendlyName: string;
	link: string;
	name: string;
	label: string;
};

const socials: Social[] = [
	{ friendlyName: "Email", link: "mailto:me@lawsonhart.me", name: "mdi:email", label: "me@lawsonhart.me" },
	{ friendlyName: "Discord", link: "https://discordapp.com/users/527167786200465418", name: "mdi:discord", label: "@wthlaw" },
	{ friendlyName: "GitHub", link: "https://github.com/oyuh/", name: "mdi:github", label: "@oyuh" },
	{ friendlyName: "LinkedIn", link: "https://www.linkedin.com/in/lawson-hart/", name: "mdi:linkedin", label: "lawson-hart" },
	{ friendlyName: "Twitter / X", link: "https://x.com/sumboutlaw/", name: "mdi:twitter", label: "@sumboutlaw" },
	{ friendlyName: "Instagram", link: "https://www.instagram.com/lawsonwtf/", name: "mdi:instagram", label: "@lawsonwtf" },
	{ friendlyName: "Buy Me A Coffee", link: "https://www.buymeacoffee.com/lawsonhart", name: "mdi:coffee", label: "lawsonhart" },
];
---

<ul class="contact-list">
	{
		socials.map((s) => (
			<li>
				<a
					class="contact-card"
					href={s.link}
					target={s.link.startsWith("mailto:") ? undefined : "_blank"}
					rel="noreferrer"
					aria-label={`${s.friendlyName}: ${s.label}`}
				>
					<span class="contact-card__icon">
						<Icon aria-hidden="true" name={s.name} />
					</span>
					<span class="contact-card__text">
						<span class="contact-card__name">{s.friendlyName}</span>
						<span class="contact-card__handle">{s.label}</span>
					</span>
				</a>
			</li>
		))
	}
</ul>
