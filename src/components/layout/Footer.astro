---
import SpotifyLogoIsland from "@/components/SpotifyLogoIsland.astro";
import { menuLinks, siteConfig } from "@/site.config";

const year = new Date().getFullYear();
---

<footer class="mt-auto w-full pt-8 pb-6 sm:pt-14 sm:pb-8">
	<div class="text-global-text/60 text-sm">
		<!-- Mobile: stacked + centered -->
		<div class="sm:hidden flex flex-col items-center gap-2.5 text-center">
			<SpotifyLogoIsland />
			<span class="text-xs font-medium">&copy; {siteConfig.author} {year}</span>
			<div class="flex items-center gap-3 text-xs">
				<a class="footer-link" href="/policy/">Policies</a>
				{menuLinks.map((link) => (
					<a class="footer-link" href={link.path}>{link.title}</a>
				))}
			</div>
		</div>

		<!-- Desktop: single centered row, logo in the middle -->
		<div class="hidden sm:flex w-full items-center justify-center gap-6">
			<div class="flex items-center gap-3">
				<span>&copy; {siteConfig.author} {year}</span>
				<span class="footer-dot">•</span>
				<a class="footer-link" href="/policy/">Policies</a>
			</div>

			<div class="flex items-center justify-center">
				<SpotifyLogoIsland />
			</div>

			<div class="flex items-center gap-3">
				{
					menuLinks.map((link, index) => (
						<>
							<a class="footer-link" href={link.path}>{link.title}</a>
							{index < menuLinks.length - 1 && <span class="footer-dot">•</span>}
						</>
					))
				}
			</div>
		</div>
	</div>
</footer>

<style>
	/* Hover = underline, not a colour change. */
	.footer-link {
		color: inherit;
		text-decoration: none;
		text-underline-offset: 3px;
	}

	.footer-link:hover,
	.footer-link:focus-visible {
		text-decoration: underline;
	}

	.footer-dot {
		color: color-mix(in srgb, var(--color-global-text) 30%, transparent);
	}
</style>
