---
import Search from "@/components/Search.astro";
import ThemeToggleOptional from "@/components/ThemeToggleOptional.astro";

// Flat, non-sticky header: search on the left, everything else on the right.
const pathname = Astro.url.pathname;
const isActive = (path: string) => pathname === path || pathname.startsWith(path);

const navLinks = [
	{ path: "/about/", title: "About" },
	{ path: "/posts/", title: "Posts" },
];
---

<header class="w-full pt-5 pb-3 sm:pt-6" id="site-header">
	<nav aria-label="Main menu" class="flex items-center justify-between gap-3">
		<div class="flex min-w-0 flex-1 items-center gap-2">
			<Search />
			{
				pathname !== "/" && (
					<a href="/" class="nav-icon" aria-label="Home" title="Home">
						<svg
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="1.7"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true"
						>
							<path d="M3 11.5 12 4l9 7.5" />
							<path d="M5 10v9a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-9" />
							<path d="M9.5 20v-5.5h5V20" />
						</svg>
					</a>
				)
			}
		</div>
		<div class="flex flex-none items-center gap-1 sm:gap-2">
			{
				navLinks.map((link) => (
					<a
						href={link.path}
						aria-current={isActive(link.path) ? "page" : undefined}
						class:list={[
							"nav-link rounded-md px-2.5 py-1.5 text-base sm:text-lg font-medium tracking-wide",
							isActive(link.path) ? "text-accent" : "text-global-text",
						]}
					>
						{link.title}
					</a>
				))
			}
			<ThemeToggleOptional />
		</div>
	</nav>
</header>

<style>
	/* Home icon button (shown when off the home page) — bare icon, accent on hover. */
	.nav-icon {
		display: inline-flex;
		flex: none;
		align-items: center;
		justify-content: center;
		height: 2.25rem;
		width: 2.25rem;
		border-radius: 0.5rem;
		color: var(--color-global-text);
		transition: color 0.2s ease, transform 0.2s ease;
	}

	.nav-icon:hover,
	.nav-icon:focus-visible {
		color: var(--color-accent);
		transform: scale(1.08);
		outline: none;
	}

	.nav-icon svg {
		height: 1.4rem;
		width: 1.4rem;
	}

	/* Hover = underline, not a colour change (matches the rest of the site). */
	.nav-link {
		text-decoration: none;
		text-underline-offset: 4px;
		text-decoration-thickness: 2px;
	}

	.nav-link:hover,
	.nav-link:focus-visible {
		text-decoration: underline;
	}
</style>
