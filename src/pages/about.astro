---
import { existsSync } from "node:fs";
import { resolve } from "node:path";
import ResumeDownload from "@/components/ResumeDownload.tsx";
import SocialList from "@/components/SocialList.astro";
import TechList from "@/components/TechList.astro";
import { getAllPosts, getTechnologyUsage } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";

const meta = {
  title: "About",
  description: "A little bit about me!",
};

const defaultResumePdfUrl = "/Lawson_Hart_Resume.pdf";
const resumePdfFsPath = resolve(process.cwd(), "public", defaultResumePdfUrl.replace(/^\//, ""));
const resumePdfExists = existsSync(resumePdfFsPath);

const allPosts = await getAllPosts();
const technologyUsage = getTechnologyUsage(allPosts);

export const prerender = true;
---
<PageLayout meta={meta} centerMain>
  <article data-pagefind-body>
    <section class="relative">
      <div class="relative z-10 py-6">
        <div class="mb-6">
          <h1 class="text-3xl md:text-4xl font-bold text-accent-2 mb-3 leading-tight">
            About Me
          </h1>
        </div>

        <div class="max-w-full space-y-4 mb-6">
          <p class="text-lg text-global-text leading-relaxed">
            Hey, I'm <span class="hero-name">Lawson Hart</span> a
            <span class="hero-accent">computer science student</span> at the
            <span class="hero-accent">University of Texas at Dallas</span>, aka The MIT of the South.
            Dallas born and raised, never really left the <span class="hero-kw">DFW</span> bubble.
          </p>

          <p class="text-base text-global-text/90 leading-relaxed">
            I'm on the computer science track with a focus on
            <span class="hero-kw">software engineering</span>/<span class="hero-kw">cyber security</span>. I take everything I find annoying or that I think I can do better
            on the internet and give it a go. Most of my projects focus on a playform with <span class="hero-accent">oAuth</span> and storing some information as I learn new technologies and frameworks.
          </p>

          <p class="text-base text-global-text/80 leading-relaxed">
            Growing up as the family's unofficial <span class="hero-kw">tech support</span> was basically my first job
            That curiosity naturally evolved into a love for <span class="hero-accent">full-stack development</span>
            and building <span class="hero-accent">web applications</span>.
            I'm a
            <span class="hero-kw">full‑stack developer</span> with a strong interest in
            <span class="hero-accent">web based applications</span>. When I’m not studying, I’m working with
            personal projects or just generally procrastinating.
          </p>

          <div class="mt-4">
            {resumePdfExists ? (
              <ResumeDownload client:load pdfUrl={defaultResumePdfUrl} />
            ) : (
              <p class="text-sm text-global-text/70">Resume PDF is not available.</p>
            )}
          </div>
        </div>

        <div class="border-t border-global-text/15 pt-6"></div>
      </div>
    </section>

    <section class="relative">
      <div class="py-4">
        <TechList techUsage={technologyUsage} />
      </div>
    </section>

    <div class="border-t border-global-text/15 my-8"></div>

    <section class="relative">
      <div class="py-4">
        <div class="mb-3">
          <h2 class="text-2xl md:text-3xl font-bold text-accent-2 leading-tight">Contact Me</h2>
        </div>

        <div class="space-y-5">
          <p class="text-base text-global-text/85 leading-relaxed">
            The quickest ways to reach me are
            <a class="lawson-link" href="mailto:me@lawsonhart.me">email</a>
            or a
            <a class="lawson-link" href="https://discordapp.com/users/527167786200465418" target="_blank" rel="noreferrer">Discord DM</a>
            — but I'm scattered across a few corners of the internet:
          </p>

          <SocialList />
        </div>
      </div>
    </section>
  </article>
</PageLayout>
