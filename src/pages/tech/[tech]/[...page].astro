---
import type { CollectionEntry } from "astro:content";
import Pagination from "@/components/Paginator.astro";
import PostPreview from "@/components/blog/PostPreview.astro";
import { getAllPosts, getTechnologyUsage } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { collectionDateSort } from "@/utils/date";
import { techSlug } from "@/utils/techIcons";
import type { GetStaticPaths, Page } from "astro";

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
	const allPosts = await getAllPosts();
	const sortedPosts = allPosts.sort(collectionDateSort);
	// Only technologies that actually appear in project posts get a page (these are
	// the "blue" ones in the TechList) — matches what shift-click links to.
	const usage = getTechnologyUsage(sortedPosts);

	return Object.values(usage).flatMap((u) => {
		const techLower = u.name.toLowerCase();
		const filterPosts = sortedPosts.filter((post) =>
			(post.data.technologies ?? []).some((t) => t.toLowerCase() === techLower),
		);
		return paginate(filterPosts, {
			pageSize: 10,
			params: { tech: techSlug(u.name) },
			props: { techName: u.name },
		});
	});
};

export const prerender = true;

interface Props {
	page: Page<CollectionEntry<"post">>;
	techName: string;
}

const { page, techName } = Astro.props;

const meta = {
	description: `View all posts that use ${techName}`,
	title: `Tech: ${techName}`,
};

const paginationProps = {
	...(page.url.prev && {
		prevUrl: {
			text: "← Previous",
			url: page.url.prev,
		},
	}),
	...(page.url.next && {
		nextUrl: {
			text: "Next →",
			url: page.url.next,
		},
	}),
};
---

<PageLayout meta={meta} centerMain>
	<div data-pagefind-ignore="all">
		<div class="mb-6 flex items-center">
			<h1 class="sr-only">Posts that use {techName}</h1>
			<a class="title text-accent underline-hover" href="/tech/"><span class="sr-only">All {" "}</span>Tech</a>
			<span aria-hidden="true" class="ms-2 me-3 text-xl">→</span>
			<span aria-hidden="true" class="text-xl">{techName}</span>
		</div>
		<section aria-labelledby={`tech-${techName}`}>
			<h2 id={`tech-${techName}`} class="sr-only">Post List</h2>
			<ul>
				{
					page.data.map((p) => (
						<li>
							<PostPreview as="h2" post={p} />
						</li>
					))
				}
			</ul>
			<Pagination {...paginationProps} />
		</section>
	</div>
</PageLayout>
