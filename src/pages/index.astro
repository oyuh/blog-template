---
import type { CollectionEntry } from "astro:content";
import HeroSocials from "@/components/HeroSocials.astro";
import PostPreview from "@/components/blog/PostPreview.astro";
import { getAllPosts } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { collectionDateSort } from "@/utils/date";

// Posts
const MAX_POSTS = 5;
const allPosts = await getAllPosts();
const publicPostCount = allPosts.filter((p) => !p.data.draft).length;
const allPostsByDate = allPosts
	.sort(collectionDateSort)
	.slice(0, MAX_POSTS) as CollectionEntry<"post">[];
---

<PageLayout meta={{ title: "Home" }} centerMain>
	<section class="hero">
		<div class="hero__text">
			<h1 id="hero-howdy" class="text-3xl md:text-4xl font-bold text-accent-2 leading-tight">
				Howdy!
				<span class="inline-block origin-bottom-right animate-wave">👋</span>
			</h1>
			<p class="text-lg text-global-text/85 leading-relaxed">
				I'm <span class="hero-name">Lawson</span> a <span class="font-semibold text-accent-2">full-stack developer &amp; software (prompt) engineer</span>.
			</p>
        <p class="mt-3 text-base text-global-text/70 leading-relaxed max-w-prose">
          I make things for all kinds of spaces and corners around the internet. I build
          things to make using a computer <span class="hero-accent">less dehumanzing</span>. I do things in the realm of <span class="hero-kw">streaming and niche gaming tools</span>. You can find more
          info about what I do using buttons.
        </p>
		</div>
		<div class="hero__art">
			<HeroSocials />
		</div>
	</section>

	<section class="mt-12 sm:mt-14">
		<div class="flex items-center justify-between mb-4">
			<h2 class="text-xl md:text-2xl font-bold text-accent-2 flex items-baseline gap-2">
				<a href="/posts/" class="underline-hover">
					Posts &amp; Projects
				</a>
				<span class="post-count">{publicPostCount}</span>
			</h2>
			<a
				href="/posts/"
				class="underline-hover text-sm font-medium text-accent inline-flex items-center gap-1"
			>
				View All
				<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
				</svg>
			</a>
		</div>
		<ul class="post-list" role="list">
			{
				allPostsByDate.map((p) => (
					<li>
						<PostPreview post={p} as="h3" />
					</li>
				))
			}
		</ul>
	</section>
</PageLayout>

<style>
	/* Waving hand animation (kept — small, purposeful) */
	@keyframes wave {
		0%, 100% { transform: rotate(-10deg); }
		50% { transform: rotate(10deg); }
	}

	.animate-wave {
		animation: wave 1.5s ease-in-out infinite;
		transform-origin: 70% 70%;
	}

	/* Hero text accents (.hero-name / .hero-kw / .hero-accent) live in global.css
	   so the About page can reuse them too. */

	/* Hero: text on the left, social collage on the right. */
	.hero {
		display: flex;
		flex-direction: column;
		gap: 1.75rem;
	}

	.hero__art {
		display: flex;
		justify-content: center;
	}

	@media (min-width: 768px) {
		.hero {
			flex-direction: row;
			align-items: center;
			justify-content: space-between;
			gap: 2.5rem;
		}
		.hero__text {
			flex: 1 1 auto;
			min-width: 0;
		}
		.hero__art {
			flex: 0 0 auto;
			justify-content: flex-end;
		}
	}

	/* "Howdy! 👋" has done its job after a moment — fade + collapse it away. */
	#hero-howdy {
		margin-bottom: 0.75rem;
		overflow: hidden;
		max-height: 4rem;
		transition: opacity 0.5s ease, max-height 0.6s ease, margin 0.5s ease, transform 0.5s ease;
	}

	#hero-howdy.is-gone {
		opacity: 0;
		max-height: 0;
		margin: 0;
		transform: translateY(-8px);
	}

	/* Tight, flat list — rows handle their own separators. */
	.post-list {
		display: flex;
		flex-direction: column;
	}

	/* Count of public posts beside the section heading. */
	.post-count {
		font-family: "Geist Mono Variable", monospace;
		font-size: 0.8rem;
		font-weight: 600;
		color: var(--color-accent);
	}

	@media (prefers-reduced-motion: reduce) {
		.animate-wave {
			animation: none !important;
		}
		#hero-howdy {
			transition: opacity 0.4s ease, max-height 0.4s ease, margin 0.4s ease;
		}
	}
</style>

<script>
	// The greeting is only useful for the first moment — retire it after a few seconds.
	function scheduleHowdyExit() {
		const el = document.getElementById("hero-howdy");
		if (!el || el.dataset.exitScheduled === "true") return;
		el.dataset.exitScheduled = "true";
		const hero = el.closest<HTMLElement>(".hero");
		window.setTimeout(() => {
			// Lock the whole hero's height first so that when the greeting collapses,
			// the (shorter) text column re-centres alongside the social icons instead of
			// the bio riding up to the top while the icons stay centred — they stay
			// vertically aligned, and the rest of the page doesn't reflow.
			if (hero) hero.style.minHeight = `${hero.offsetHeight}px`;
			el.classList.add("is-gone");
		}, 4000);
	}

	scheduleHowdyExit();
	document.addEventListener("astro:page-load", scheduleHowdyExit);
</script>
