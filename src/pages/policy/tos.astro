---
import PageLayout from "@/layouts/Base.astro";
import PolicyNav from "@/components/policy/PolicyNav.astro";

const meta = {
  title: "Terms of Service",
  description: "The rules for using lawsonhart.me, the comments service, and the games service. Last Updated: April 26, 2026",
};

export const prerender = true;
---

<PageLayout meta={meta}>
  <article data-pagefind-body>
    <h1 class="text-4xl font-bold mb-4 text-accent-2 tracking-tight">Terms of Service</h1>

    <div class="prose prose-base dark:prose-invert max-w-none">
      <p class="leading-relaxed">
        Using this site or related services under my domains means you agree to these terms. If you do not
        agree, do not use them.
      </p>

      <div class="mt-4 inline-flex items-center gap-2 px-3 py-1.5 rounded-lg bg-global-bg/60 ring-1 ring-white/5 backdrop-blur-md text-sm font-medium tracking-tight shadow-[0_6px_16px_-10px_rgba(0,0,0,0.35)]">
        <span class="text-accent-2">Last Updated</span>
        <span class="text-global-text/80">April 26, 2026</span>
        <span class="hidden sm:inline text-global-text/50">(Terms of Service)</span>
      </div>

      <PolicyNav current="terms" />

      <h2 class="text-accent-2">Use of the Site</h2>
      <p>
        This site and related services are for informational, creative, and entertainment purposes. Do not
        use them for illegal, abusive, disruptive, deceptive, or harmful activity.
      </p>

      <h2 class="text-accent-2">Comments Service</h2>
      <p>
        The comments service may require GitHub sign-in. You are responsible for comments, replies,
        reactions, and other activity submitted through your authenticated session.
      </p>
      <p>
        Do not use the comments service to harass others, impersonate people, spam, post unlawful or
        infringing material, attempt to bypass moderation, or interfere with the service. I may moderate,
        hide, edit, remove, or restrict comment access at my discretion.
      </p>

      <h2 class="text-accent-2">Games Service</h2>
      <p>
        The games website is provided for casual use and may reset, expire, or delete temporary room data,
        submissions, chat, and similar gameplay content automatically, usually within about 24 hours. Do
        not rely on it for long-term storage.
      </p>
      <p>
        You may not use the games service to disrupt rooms, abuse other players, automate harmful behavior,
        scrape personal data from gameplay, or submit unlawful or abusive content. I may suspend or block
        access to protect the service or other users.
      </p>

      <h2 class="text-accent-2">Accounts and Authentication</h2>
      <p>
        If you authenticate through GitHub or use any session-based feature, you are responsible for
        activity associated with that access. I may revoke sessions or restrict access when needed for
        security, moderation, or abuse prevention.
      </p>

      <h2 class="text-accent-2">Content</h2>
      <p>
        Site content belongs to me (Lawson Hart) or appears with permission. Content you submit remains
        yours, but you grant me permission to host, process, display, moderate, and remove it as needed to
        operate the website, comments service, and games service.
      </p>

      <h2 class="text-accent-2">Privacy</h2>
      <p>
        See the <a href="/policy/privacy" class="text-accent hover:underline">Privacy Policy</a> for data
        handling details.
      </p>

      <h2 class="text-accent-2">Termination</h2>
      <p>I may suspend, block, or remove access for any reason, especially policy or rule violations.</p>

      <h2 class="text-accent-2">External Links</h2>
      <p>
        Linked third party sites are outside my control. I am not responsible for their content, practices,
        or conduct.
      </p>

      <h2 class="text-accent-2">Changes</h2>
      <p>These terms may change. The date above updates when they do.</p>
    </div>
  </article>
</PageLayout>
