---
import { getAllPosts, getUniqueTagsWithCount } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";

const allPosts = await getAllPosts();
const allTags = getUniqueTagsWithCount(allPosts);

const tagCards = allTags.map(([tag, count]) => {
	const postsWithTag = allPosts
		.filter((post) => post.data.tags.includes(tag))
		.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

	const cover = postsWithTag.find((post) => post.data.coverImage?.src?.src)?.data.coverImage;
	const coverSrc = cover?.src?.src ?? null;

	const featuredPosts = postsWithTag.slice(0, 3).map((post) => ({
		id: post.id,
		title: post.data.title,
	}));

	return { tag, count, coverSrc, featuredPosts };
});

const meta = {
	description: "Explore every tag on the site and jump into recent posts that use it.",
	title: "All Tags",
};
---

<PageLayout meta={meta} centerMain>
	<div data-pagefind-ignore="all">
		<div class="mb-10 space-y-3">
			<h1 class="title text-3xl">Tags</h1>
			<p class="max-w-2xl text-base text-global-text/80 dark:text-global-text/70">
				Browse every topic I write about — each one jumps to the posts that use it.
			</p>
		</div>
		<div class="index-grid">
			{
				tagCards.map(({ tag, count, coverSrc, featuredPosts }) => (
					<a
						class="index-card"
						data-astro-prefetch
						href={`/tags/${tag}/`}
						title={`View ${count} post${count === 1 ? "" : "s"} tagged with ${tag}`}
					>
						{coverSrc ? (
							<div class="index-card__img" style={`background-image: url(${coverSrc});`} aria-hidden="true" />
						) : (
							<div class="index-card__img index-card__img--none" aria-hidden="true" />
						)}
						<div class="index-card__body">
							<span class="index-card__kicker">Tag</span>
							<h2 class="index-card__title">#{tag}</h2>
							<span class="index-card__count">
								{count} post{count === 1 ? "" : "s"}
							</span>
							{featuredPosts.length > 0 && (
								<ul class="index-card__posts">
									{featuredPosts.map((post) => (
										<li class="index-card__post">
											<span class="index-card__dot" aria-hidden="true" />
											<span class="truncate">{post.title}</span>
										</li>
									))}
								</ul>
							)}
						</div>
					</a>
				))
			}
		</div>
	</div>
</PageLayout>
