{
  "name": "blog",
  "version": "2.2-site-info",
  "scripts": {
    "dev": "node scripts/clean-dev-cache.cjs && astro dev",
    "start": "bun run dev",
    "template:dev": "node scripts/template-sandbox.cjs dev",
    "template:build": "node scripts/template-sandbox.cjs build",
    "ci:local:linux": "bun run check && bun run build",
    "ci:local:win": "bun run check ; bun run build",
    "build": "astro build --remote",
    "postbuild": "node scripts/pagefind.mjs",
    "preview": "node scripts/preview.mjs",
    "lint": "biome lint .",
    "format": "bun run format:code && bun run format:imports",
    "format:code": "biome format . --write && prettier -w \"**/*\" \"!**/*.{md,mdx}\" --ignore-unknown --cache",
    "format:imports": "biome check --formatter-enabled=false --write",
    "check": "astro check"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/mdx": "5.0.6",
    "@astrojs/node": "^10.1.4",
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "3.7.3",
    "@astrojs/vercel": "^10.0.8",
    "@astrojs/vue": "^6.0.1",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@iconify/vue": "^5.0.1",
    "@libsql/client": "^0.17.3",
    "@tailwindcss/vite": "4.3.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "aos": "^2.3.4",
    "astro": "6.4.6",
    "astro-expressive-code": "^0.43.1",
    "astro-icon": "^1.1.5",
    "astro-robots-txt": "^1.0.0",
    "astro-webmanifest": "^1.0.0",
    "baffle": "^0.3.6",
    "boneyard-js": "^1.8.1",
    "chart.js": "^4.5.1",
    "cssnano": "^8.0.2",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "drizzle-orm": "^0.45.2",
    "hastscript": "^9.0.1",
    "mdast-util-directive": "^3.1.0",
    "mdast-util-to-markdown": "^2.1.2",
    "mdast-util-to-string": "^4.0.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-expressive-code": "^0.43.1",
    "rehype-external-links": "^3.0.0",
    "rehype-unwrap-images": "^1.0.0",
    "remark-directive": "^4.0.0",
    "satori": "0.26.0",
    "satori-html": "^0.3.2",
    "sharp": "^0.34.5",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vite": "^7.3.5",
    "vue": "^3.5.39",
    "vue-chartjs": "^5.3.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^2.5.0",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/simple-icons": "^1.2.86",
    "@netlify/functions": "^5.3.0",
    "@pagefind/default-ui": "^1.5.2",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/typography": "^0.5.20",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.9.3",
    "@vercel/node": "^5.8.17",
    "autoprefixer": "^10.5.0",
    "pagefind": "^1.5.2",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "reading-time": "^1.5.0",
    "tailwindcss": "4.3.1",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "esbuild": "^0.25.10",
    "sharp": "^0.34.5",
    "smol-toml": "^1.6.1",
    "yaml": "^2.9.0"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "@tailwindcss/oxide"
  ]
}
