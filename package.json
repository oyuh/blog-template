{
  "name": "blog",
  "version": "2.2-site-info",
  "scripts": {
    "dev": "node scripts/clean-dev-cache.cjs && astro dev",
    "start": "bun run dev",
    "postinstall": "node scripts/patch-astrojs-mdx-server.cjs",
    "template:dev": "node scripts/template-sandbox.cjs dev",
    "template:build": "node scripts/template-sandbox.cjs build",
    "ci:local:linux": "bun run check && bun run build",
    "ci:local:win": "bun run check ; bun run build",
    "build": "astro build --remote",
    "postbuild": "node scripts/pagefind.mjs",
    "preview": "node scripts/preview.mjs",
    "lint": "biome lint .",
    "format": "bun run format:code && bun run format:imports",
    "format:code": "biome format . --write && prettier -w \"**/*\" \"!**/*.{md,mdx}\" --ignore-unknown --cache",
    "format:imports": "biome check --formatter-enabled=false --write",
    "check": "astro check"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.1.2",
    "@astrojs/mdx": "5.0.6",
    "@astrojs/node": "^10.1.1",
    "@astrojs/react": "^5.0.5",
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "3.7.2",
    "@astrojs/vercel": "^10.0.7",
    "@heroui/card": "^2.2.28",
    "@heroui/progress": "^2.2.25",
    "@heroui/react": "^3.0.5",
    "@iconify/react": "^6.0.2",
    "@libsql/client": "^0.17.3",
    "@tailwindcss/vite": "4.3.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "aos": "^2.3.4",
    "astro": "6.3.7",
    "astro-expressive-code": "^0.42.0",
    "astro-icon": "^1.1.5",
    "astro-robots-txt": "^1.0.0",
    "astro-webmanifest": "^1.0.0",
    "baffle": "^0.3.6",
    "boneyard-js": "^1.8.1",
    "cssnano": "^8.0.1",
    "date-fns": "^4.2.1",
    "date-fns-tz": "^3.2.0",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.40.0",
    "hastscript": "^9.0.1",
    "mdast-util-directive": "^3.1.0",
    "mdast-util-to-markdown": "^2.1.2",
    "mdast-util-to-string": "^4.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-external-links": "^3.0.0",
    "rehype-unwrap-images": "^1.0.0",
    "remark-directive": "^4.0.0",
    "satori": "0.26.0",
    "satori-html": "^0.3.2",
    "sharp": "^0.34.5",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vite": "^7.3.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^2.4.15",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/simple-icons": "^1.2.83",
    "@netlify/functions": "^5.2.2",
    "@pagefind/default-ui": "^1.5.2",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.8.3",
    "autoprefixer": "^10.5.0",
    "pagefind": "^1.5.2",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "reading-time": "^1.5.0",
    "tailwindcss": "4.3.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "esbuild": "^0.25.10",
    "sharp": "^0.34.5"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "@heroui/shared-utils",
    "@tailwindcss/oxide"
  ]
}
